# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Database (Supabase PostgreSQL)
# Use the Pooler connection for app queries
DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
# Use the Direct connection for migrations (Prisma)
DIRECT_DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# Judge0 CE API Key (RapidAPI)
# Get from: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=your-judge0-api-key-here
